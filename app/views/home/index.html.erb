    <h2 class="text-2xl font-bold text-slate-800 text-center mb-12">Skills</h2>
    <div class="flex flex-wrap justify-center gap-3 max-w-2xl mx-auto">
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">Ruby</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">Ruby on Rails</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">JavaScript</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">TypeScript</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">React</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">Next.js</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">jQuery</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">AWS</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">Docker</span>
      <span class="px-4 py-2 bg-slate-100 text-slate-700 rounded-full text-sm font-medium">MySQL</span>
    </div>
  </div>
</section>

<section class="bg-slate-50 py-20">
  <div class="container mx-auto px-6 text-center">
    <h2 class="text-2xl font-bold text-slate-800 mb-4">Blog</h2>
    <p class="text-slate-500">Coming Soon</p>
  </div>
</section>

