<% content_for :title, "ダッシュボード | Admin" %>

<h1 class="text-2xl font-bold text-slate-800 mb-8">ダッシュボード</h1>

<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
  <%= link_to admin_blog_posts_path,
        class: "bg-white rounded-xl shadow hover:shadow-md transition-shadow p-6 flex items-center gap-4 group" do %>
    <div class="bg-indigo-100 text-indigo-600 rounded-lg p-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
      </svg>
    </div>
    <div>
      <p class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">ブログ記事</p>
      <p class="text-sm text-slate-400">記事の作成・編集・管理</p>
    </div>
  <% end %>

  <%= link_to admin_categories_path,
        class: "bg-white rounded-xl shadow hover:shadow-md transition-shadow p-6 flex items-center gap-4 group" do %>
    <div class="bg-indigo-100 text-indigo-600 rounded-lg p-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7a2 2 0 012-2h4l2 2h6a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V7z" />
      </svg>
    </div>
    <div>
      <p class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors">カテゴリー</p>
      <p class="text-sm text-slate-400">カテゴリーの作成・編集・管理</p>
    </div>
  <% end %>

  <%= link_to admin_inquiries_path,
        class: "bg-white rounded-xl shadow hover:shadow-md transition-shadow p-6 flex items-center gap-4 group" do %>
    <div class="bg-indigo-100 text-indigo-600 rounded-lg p-3">
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
    </div>
    <div>
      <p class="font-semibold text-slate-800 group-hover:text-indigo-600 transition-colors flex items-center gap-2">
        お問い合わせ
        <% if @unread_inquiry_count > 0 %>
          <span class="text-xs font-medium bg-red-100 text-red-700 px-2 py-0.5 rounded-full"><%= @unread_inquiry_count %></span>
        <% end %>
      </p>
      <p class="text-sm text-slate-400">お問い合わせの確認・管理</p>
    </div>
  <% end %>
</div>
