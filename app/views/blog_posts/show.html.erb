<% content_for :title, "#{@blog_post.title} | Blog" %>

<% if local_assigns[:preview_mode] %>
  <div class="bg-amber-400 text-amber-900 text-center py-3 px-6 text-sm font-medium">
    プレビュー表示中です。
    <%= link_to "管理画面へ戻る", admin_blog_post_path(@blog_post), class: "underline ml-2 font-semibold" %>
  </div>
<% end %>

<div class="bg-slate-50 min-h-screen">
  <div class="container mx-auto px-6 py-12 max-w-3xl">
    <div class="mb-6">
      <%= link_to "← ブログ一覧", blog_posts_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
    </div>

    <article class="bg-white rounded-xl shadow p-8">
      <header class="mb-8">
        <% if @blog_post.category %>
          <span class="text-xs font-medium text-indigo-600 bg-indigo-50 px-2 py-1 rounded-full">
            <%= @blog_post.category.name %>
          </span>
        <% end %>
        <h1 class="text-3xl font-bold text-slate-800 mt-4 mb-2"><%= @blog_post.title %></h1>
        <% if @blog_post.published_at %>
          <time class="text-slate-400 text-sm" datetime="<%= @blog_post.published_at.iso8601 %>">
            <%= @blog_post.published_at.strftime("%Y年%m月%d日") %>
          </time>
        <% end %>
      </header>

      <%= @blog_post.content %>
    </article>
  </div>
</div>
