{
  "name": "my-site-devcontainer",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/rails/.claude"
  },
  "mounts": [
    "source=claude-code-config,target=/home/rails/.claude,type=volume",
    "source=gh-config,target=/home/rails/.config/gh,type=volume"
  ],
  "remoteUser": "rails",
  "initializeCommand": "docker run --rm -v claude-code-config:/home/rails/.claude -v gh-config:/home/rails/.config/gh alpine chown -R 1000:1000 /home/rails/.claude /home/rails/.config/gh"
}
