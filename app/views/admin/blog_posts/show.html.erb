<% content_for :title, "#{@blog_post.title} | Admin" %>

<div class="flex flex-col gap-4 mb-6 sm:flex-row sm:justify-between sm:items-start">
  <div>
    <div class="flex items-center gap-2 mb-2">
      <%= link_to "← 記事一覧", admin_blog_posts_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
    </div>
    <h1 class="text-2xl font-bold text-slate-800"><%= @blog_post.title %></h1>
    <div class="flex flex-wrap items-center gap-3 mt-2">
      <% if @blog_post.published? %>
        <span class="px-2 py-1 bg-green-100 text-green-800 rounded text-xs font-medium">公開中</span>
      <% else %>
        <span class="px-2 py-1 bg-slate-100 text-slate-600 rounded text-xs font-medium">下書き</span>
      <% end %>
      <% if @blog_post.category %>
        <span class="text-slate-400 text-sm"><%= @blog_post.category.name %></span>
      <% end %>
      <% if @blog_post.published_at %>
        <span class="text-slate-400 text-xs"><%= @blog_post.published_at.strftime("%Y/%m/%d %H:%M") %></span>
      <% end %>
    </div>
  </div>
  <div class="flex gap-2 flex-wrap">
    <%= link_to "編集", edit_admin_blog_post_path(@blog_post),
          class: "bg-slate-900 hover:bg-slate-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
    <%= link_to "プレビュー", preview_admin_blog_post_path(@blog_post), target: "_blank",
          class: "border border-slate-300 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
    <% if @blog_post.published? %>
      <%= button_to "非公開にする", unpublish_admin_blog_post_path(@blog_post),
            class: "bg-amber-100 hover:bg-amber-200 text-amber-800 px-4 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    <% else %>
      <%= button_to "公開する", publish_admin_blog_post_path(@blog_post),
            class: "bg-green-600 hover:bg-green-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    <% end %>
    <%= button_to "削除", admin_blog_post_path(@blog_post), method: :delete,
          data: { turbo_confirm: "本当に削除しますか？" },
          class: "bg-red-100 hover:bg-red-200 text-red-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
  </div>
</div>

<div class="bg-white rounded-xl shadow p-6">
  <%= @blog_post.content %>
</div>
