{
  "name": "my-site-devcontainer",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {},
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "moby": false
    }
  },
  "containerEnv": {
    "CLAUDE_CONFIG_DIR": "/home/rails/.claude",
    "RAILS_ENV": "development",
    // Dockerfile の BUNDLE_DEPLOYMENT=1 を上書きして bundle install を可能にする
    "BUNDLE_DEPLOYMENT": "0",
    // Dockerfile の BUNDLE_WITHOUT=development を上書きして開発用 gem を読み込む
    "BUNDLE_WITHOUT": ""
  },
  "mounts": [
    "source=claude-code-config,target=/home/rails/.claude,type=volume",
    "source=gh-config,target=/home/rails/.config/gh,type=volume",
    "source=ssh-config,target=/home/rails/.ssh,type=volume"
  ],
  // macOS Docker Desktop では /var/run/docker-host.sock が root:root 所有のため、
  // rails ユーザーがアクセスするには root グループへの追加が必要。
  // docker-init.sh による socat relay は sudo が必要なため利用不可。
  "runArgs": ["--group-add=root"],
  "remoteUser": "rails",
  "initializeCommand": "docker run --rm -v claude-code-config:/home/rails/.claude -v gh-config:/home/rails/.config/gh -v ssh-config:/home/rails/.ssh alpine chown -R 1000:1000 /home/rails/.claude /home/rails/.config/gh /home/rails/.ssh"
}
