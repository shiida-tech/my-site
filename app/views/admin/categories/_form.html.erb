<%= form_with model: [:admin, category], class: "space-y-5" do |form| %>
  <% if category.errors.any? %>
    <div class="p-4 bg-red-100 text-red-800 rounded-lg text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% category.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :name, "カテゴリー名", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_field :name,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
          placeholder: "例: Ruby on Rails" %>
  </div>

  <div class="flex justify-between items-center pt-4 border-t border-slate-200">
    <%= link_to "キャンセル", admin_categories_path, class: "text-slate-500 hover:text-slate-700 text-sm" %>
    <%= form.submit category.persisted? ? "更新する" : "作成する",
          class: "bg-slate-900 hover:bg-slate-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
  </div>
<% end %>
