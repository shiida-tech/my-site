<% content_for :title, "カテゴリー一覧 | Admin" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-slate-800">カテゴリー</h1>
  <%= link_to "新規作成", new_admin_category_path,
        class: "bg-indigo-600 hover:bg-indigo-500 text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
</div>

<div class="bg-white rounded-xl shadow overflow-x-auto">
  <table class="w-full min-w-max text-sm">
    <thead class="bg-slate-50 border-b border-slate-200">
      <tr>
        <th class="px-4 py-3 text-left text-slate-600 font-medium">名前</th>
        <th class="px-4 py-3 text-left text-slate-600 font-medium">記事数</th>
        <th class="px-4 py-3 text-left text-slate-600 font-medium">操作</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-slate-100">
      <% @categories.each do |category| %>
        <tr class="hover:bg-slate-50">
          <td class="px-4 py-3 font-medium text-slate-800"><%= category.name %></td>
          <td class="px-4 py-3 text-slate-500"><%= category.blog_posts.count %></td>
          <td class="px-4 py-3">
            <div class="flex gap-3">
              <%= link_to "編集", edit_admin_category_path(category),
                    class: "text-indigo-600 hover:text-indigo-500 font-medium" %>
              <%= button_to "削除", admin_category_path(category), method: :delete,
                    data: { turbo_confirm: "本当に削除しますか？関連記事のカテゴリーは空になります。" },
                    class: "text-red-600 hover:text-red-500 font-medium cursor-pointer bg-transparent border-0 p-0" %>
            </div>
          </td>
        </tr>
      <% end %>
      <% if @categories.empty? %>
        <tr>
          <td colspan="3" class="px-4 py-8 text-center text-slate-400">カテゴリーがまだありません。</td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
