<%= form_with model: [:admin, blog_post], class: "space-y-6" do |form| %>
  <% if blog_post.errors.any? %>
    <div class="p-4 bg-red-100 text-red-800 rounded-lg text-sm">
      <ul class="list-disc list-inside space-y-1">
        <% blog_post.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= form.label :title, "タイトル", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_field :title,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
          placeholder: "記事のタイトルを入力" %>
  </div>

  <div class="mb-4">
    <%= form.label :slug, "スラッグ（URL）", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.text_field :slug,
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 font-mono",
          placeholder: "空欄で自動生成（例: a3f8c2b1）" %>
    <p class="text-xs text-slate-400 mt-1">半角英小文字・数字・ハイフンのみ。空欄でタイトルから自動生成します。</p>
  </div>

  <div class="mb-4">
    <%= form.label :category_id, "カテゴリー", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.collection_select :category_id, Category.ordered, :id, :name,
          { include_blank: "カテゴリーなし" },
          class: "w-full border border-slate-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
  </div>

  <div class="mb-6">
    <%= form.label :content, "本文", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= form.rich_text_area :content, class: "min-h-64" %>
  </div>

  <div class="flex flex-col gap-3 pt-6 border-t border-slate-200 sm:flex-row sm:justify-between sm:items-center">
    <%= link_to "キャンセル", admin_blog_posts_path, class: "text-slate-500 hover:text-slate-700 text-sm" %>
    <div class="flex gap-3">
      <% if blog_post.persisted? %>
        <%= link_to "プレビュー", preview_admin_blog_post_path(blog_post), target: "_blank",
              class: "border border-slate-300 hover:bg-slate-200 text-slate-700 px-4 py-2 rounded-lg text-sm font-medium transition-colors" %>
      <% end %>
      <%= form.submit blog_post.persisted? ? "更新する" : "下書き保存",
            class: "bg-slate-900 hover:bg-slate-700 text-white px-6 py-2 rounded-lg text-sm font-medium transition-colors cursor-pointer" %>
    </div>
  </div>
<% end %>
