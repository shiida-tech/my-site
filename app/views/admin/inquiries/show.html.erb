<% content_for :title, "お問い合わせ詳細 | Admin" %>

<div class="mb-6">
  <%= link_to "← お問い合わせ一覧", admin_inquiries_path, class: "text-slate-400 hover:text-slate-600 text-sm" %>
</div>

<div class="bg-white rounded-xl shadow p-6 space-y-6">
  <div>
    <h1 class="text-2xl font-bold text-slate-800 mb-4">お問い合わせ詳細</h1>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-4 text-sm">
      <div>
        <dt class="text-slate-500 font-medium mb-1">氏名</dt>
        <dd class="text-slate-800"><%= @inquiry.name %></dd>
      </div>
      <div>
        <dt class="text-slate-500 font-medium mb-1">会社名・屋号</dt>
        <dd class="text-slate-800"><%= @inquiry.company_name.presence || "（未入力）" %></dd>
      </div>
      <div>
        <dt class="text-slate-500 font-medium mb-1">メールアドレス</dt>
        <dd class="text-slate-800"><%= mail_to @inquiry.email, @inquiry.email, class: "text-indigo-600 hover:text-indigo-500" %></dd>
      </div>
      <div>
        <dt class="text-slate-500 font-medium mb-1">受信日時</dt>
        <dd class="text-slate-800"><%= @inquiry.created_at.strftime("%Y年%m月%d日 %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <div class="border-t border-slate-200 pt-6">
    <h2 class="text-sm font-medium text-slate-500 mb-3">お問い合わせ内容</h2>
    <div class="text-slate-800 whitespace-pre-wrap leading-relaxed"><%= @inquiry.body %></div>
  </div>
</div>
